# dependencies
node_modules/

# build output
/build/
/.svelte-kit/
/package/

# tauri
/src-tauri/target/
/src-tauri/gen/
# bundled ffmpeg sidecar (fetched per-platform in CI, never committed)
/src-tauri/binaries/

# env / editor
# Vite loads .env, .env.local and .env.<mode>. FoxCull uses none today, but an
# untracked-yet-unignored .env is how secrets leak — ignore the whole family.
.env.*
!.env.example
.env
.DS_Store
*.log
*.local
.vscode/*
!.vscode/extensions.json
